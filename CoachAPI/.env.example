PORT=3000
JWT_SECRET=change-me-to-at-least-32-bytes-long-secret!!
COACH_DEV_AUTH_BYPASS=1
COACH_UPSTREAM_BASE_URL=https://oraiapi.com/v1
COACH_UPSTREAM_API_KEY=dev-key
COACH_MODEL_DEFAULT=gpt-oss-120b
COACH_MODEL_DEEP=gpt-oss-120b
# Tiers are chosen by the client (Coach vs Deeper insight in-app). Same upstream base for both.
# oraiapi.com is the current default upstream (supports tools + OpenAI chat completions compat).
# Alternative (dev only): OpenCode Zen
# COACH_UPSTREAM_BASE_URL=https://opencode.ai/zen/v1
# COACH_MODEL_DEFAULT=deepseek-v4-flash-free
CORS_ORIGINS=*