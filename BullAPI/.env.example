PORT=3000
JWT_SECRET=change-me-to-at-least-32-bytes-long-secret!!
BULL_DEV_AUTH_BYPASS=1
BULL_UPSTREAM_BASE_URL=https://oraiapi.com/v1
BULL_UPSTREAM_API_KEY=dev-key
BULL_MODEL_DEFAULT=gpt-oss-120b
BULL_MODEL_DEEP=gpt-oss-120b
# Tiers are chosen by the client (Coach vs Deeper insight in-app). Same upstream base for both.

# --- Persistence (Postgres) ---
# BullAPI stores device-originated WHOOP 5 data here so the web app can read it
# and so raw uploads can be inspected for debugging. Data is per-user.
DATABASE_URL=postgres://bull:bull@localhost:5432/bull

# --- Sign in with Apple ---
# APPLE_BUNDLE_ID is the audience BullAPI requires in Apple identity tokens.
# APPLE_ISSUER is fixed; override only for tests.
APPLE_BUNDLE_ID=com.bull.swift
APPLE_ISSUER=https://appleid.apple.com

CORS_ORIGINS=*
